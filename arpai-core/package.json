{
  "name": "arpai-core",
  "version": "1.0.0",
  "description": "Production-grade backend for ARPAI lead operations",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "test": "node --test dist/tests/*.test.js",
    "test:local": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.54.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "openai": "^4.104.0",
    "twilio": "^5.7.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^20.17.50",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
